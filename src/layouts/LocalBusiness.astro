  "@type": "LocalBusiness",
  "@id": `"${siteUrl ?? null}"`,
  name: `"${businessName ?? null}"`,
  description:
    "Professional landscaping services including lawn care, garden design, tree trimming, and outdoor maintenance for residential and commercial properties.",
