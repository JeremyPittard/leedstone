  image: [
    "https://www.greenthumblandscaping.com/images/landscaping-work-1.jpg",
    "https://www.greenthumblandscaping.com/images/landscaping-work-2.jpg",
    "https://www.greenthumblandscaping.com/images/landscaping-work-3.jpg",
  ],
  telephone: "+1-555-123-4567",
  email: "info@greenthumblandscaping.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "1234 Garden Lane",
    addressLocality: "Springfield",
    addressRegion: "IL",
    postalCode: "62701",
    addressCountry: "US",
  },
  geo: {
