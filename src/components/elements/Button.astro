---
import type { HTMLAttributes } from "astro/types";

type ButtonVariant = "primary" | "secondary" | "outline" | "ghost";
type IconType = string | "icon-only";
interface LinkProps extends HTMLAttributes<"a"> {
  buttonType: "link";
}

type iconPosition = "leading" | "trailing";

interface ButtonProps extends HTMLAttributes<"button"> {
  buttonType: "button";
}

type Props = {
  variant: ButtonVariant;
} & (LinkProps | ButtonProps);
const props: Props = Astro.props;

const bgColorMap = {
  primary: "bg-neutral-darkest",
  secondary: "bg-neutral-lightest",
  ghost: "bg-none",
  outline: "bg-none",
};

const textColorMap = {
  primary: "text-white",
  secondary: "text-neutral-darkest",
  ghost: "text-neutral-darkest",
  outline: "text-neutral-darkest",
};

const borderColorMap = {
  primary: "border-transparent",
  secondary: "border-transparent", //this will need to match primary color when set
  ghost: "border-transparent",
  outline: "border-neutral-darkest",
};

const buttonClasses: string = `${props.class?.includes("block") ? "" : "inline-block"} ${bgColorMap[props.variant]} ${textColorMap[props.variant]} border ${borderColorMap[props.variant]} px-6 py-3`;
---

{
  props.buttonType === "link" ? (
    <a
      class:list={buttonClasses}
      class={props.class}
      href={props.href}
      target={props.target}
    >
      <slot />
    </a>
  ) : (
    <button class={buttonClasses} type={props.type}>
      <slot />
    </button>
  )
}

<style>
  .button {
    line-height: 1.4;
  }
</style>
