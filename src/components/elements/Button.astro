---
import type { HTMLAttributes } from "astro/types";
import { Icon } from "astro-icon/components";

type ButtonVariant =
  | "primary"
  | "secondary"
  | "outline"
  | "ghost"
  | "ghost-alt"
  | "more"
  | "alt";
type IconType = string | "icon-only";
interface LinkProps extends HTMLAttributes<"a"> {
  buttonType: "link";
}

type iconPosition = "leading" | "trailing";

interface ButtonProps extends HTMLAttributes<"button"> {
  buttonType: "button";
}

type Props = {
  variant: ButtonVariant;
  size?: "small" | "regular";
  iconPosition?: iconPosition;
} & (LinkProps | ButtonProps);
const props: Props = Astro.props;

// Extract element-specific attributes and class so we can forward the rest (id, aria-*, data-*, etc.)
const {
  buttonType,
  class: className,
  href,
  target,
  type,
  ...rest
} = props as any;

const bgColorMap = {
  primary: "bg-brand-1 primary hover:bg-brand-2",
  secondary: "bg-brand-3 secondary hover:bg-brand-2",
  ghost: "bg-none ghost",
  "ghost-alt": "bg-none ghost-alt",
  more: "bg-none more ghost nav",
  outline: "bg-none outline hover:bg-brand-2",
  alt: "bg-background-alt alt",
};

const textColorMap = {
  primary: "text-white hover:text-text",
  secondary: "text-text",
  ghost: "text-text",
  "ghost-alt": "text-text-alt",
  more: "text-text",
  outline: "text-text",
  alt: "text-text-alt",
};

const borderColorMap = {
  primary: "border-transparent",
  secondary: "border-transparent", //this will need to match primary color when set
  ghost: "border-transparent",
  "ghost-alt": "border-transparent",
  more: "border-transparent",
  outline: "border-neutral-darkest",
  alt: "border-text-alt",
};

const buttonSizeMap = {
  small: "px-5 py-2",
  regular: "px-6 py-3",
};

const buttonClasses: string = `btn ${className?.includes("block") ? "" : "inline-block"} ${props.size ? buttonSizeMap[props.size] : props.variant === "more" ? "px-0 py-2" : buttonSizeMap.regular} ${bgColorMap[props.variant]} ${textColorMap[props.variant]} border ${borderColorMap[props.variant]} duration-150 `;
---

{
  buttonType === "link" ? (
    <a
      class:list={[buttonClasses, className]}
      href={href}
      target={target}
      {...rest}
    >
      {props.variant === "ghost" && props.iconPosition === "leading" ? (
        <Icon
          name="mdi:navigate-next"
          class={`inline-block ${props.size === "small" ? "ml-1" : "ml-2"} rotate-180`}
        />
      ) : null}
      <slot />
      {(props.variant === "ghost" && props.iconPosition !== "leading") ||
      props.variant === "more" ? (
        <Icon
          name="mdi:navigate-next"
          class={`inline-block ${props.size === "small" ? "ml-1" : "ml-2"}`}
        />
      ) : null}
    </a>
  ) : (
    <button class:list={[buttonClasses, className]} type={type} {...rest}>
      <slot />
    </button>
  )
}

<style>
  .button {
    line-height: 1.4;
  }
</style>
