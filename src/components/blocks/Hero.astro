---
import type { CTALink } from "../../types/blocks";
import Button from "../elements/Button.astro";
import PageSection from "../objects/PageSection.astro";

import { Icon } from "astro-icon/components";

const { value } = Astro.props;

const { image, title, description, cta } = value;
---

<PageSection class="hero">
  <h1>it's a me a hero</h1>
  <Icon name="ri:twitter-x-line" />
  <Icon name="tabler:brand-threads" />
</PageSection>
<section class="Hero">
  <div class="">
    <div class="max-w-lg mx-auto">
      <h1 class="text-tiny">
        {title}
      </h1>
      <p class="mt-6 text-gray-500">
        {description}
      </p>
      <div class="flex gap-4 items-center justify-center">
        {
          cta
            ? cta.map((link: CTALink) => (
                <Button
                  buttonType="link"
                  variant="primary"
                  href={link.value.link}
                >
                  {link.value.linkText}
                  {link.value.link}
                </Button>
              ))
            : null
        }
      </div>

      <p class="mt-3 text-large text-gray-400">No credit card required</p>
    </div>

    <div class="flex justify-center mt-10">
      <img class="object-cover w-full h-96 rounded-xl" src={image} />
    </div>
  </div>
</section>
