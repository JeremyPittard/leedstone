---
import type { CTALink } from "../../types/blocks";

const { value } = Astro.props;

const { image, title, description, cta, imageSide } = value;

const imageSideClasses =
  imageSide === "right" ? "xl:flex-row-reverse" : "xl:flex-row";
---

<section class="text-with-image bg-white">
  <div
    class={`container flex flex-col items-center px-4 py-12 mx-auto ${imageSideClasses}`}
  >
    <div class="flex justify-center xl:w-1/2">
      <img
        class="h-80 w-80 sm:w-[28rem] sm:h-[28rem] flex-shrink-0 object-cover rounded-lg"
        src={image}
        alt=""
      />
    </div>

    <div
      class="flex flex-col items-center mt-6 xl:items-start xl:w-1/2 xl:mt-0"
    >
      <h2
        class="text-2xl font-semibold tracking-tight text-gray-800 xl:text-3xl"
      >
        {title}
      </h2>

      <p class="block max-w-2xl mt-4 text-gray-500">
        {description}
      </p>

      <div class="mt-6 sm:-mx-2">
        {
          cta
            ? cta.map((link: CTALink, index: number) => {
                return index === 0 ? (
                  <a
                    class="inline-flex items-center justify-center w-full px-4 text-sm py-2.5 mt-4 overflow-hidden text-white transition-colors duration-300 bg-blue-600 rounded-lg shadow sm:w-auto sm:mx-2 sm:mt-0 hover:bg-blue-500 focus:ring focus:ring-blue-300 focus:ring-opacity-80"
                    href={link.value.link}
                  >
                    {link.value.linkText}
                  </a>
                ) : (
                  <a
                    class="inline-flex items-center justify-center w-full px-4 text-sm py-2.5 overflow-hidden text-white transition-colors duration-300 bg-gray-900 rounded-lg shadow sm:w-auto sm:mx-2 hover:bg-gray-700  focus:ring focus:ring-gray-300 focus:ring-opacity-80"
                    href={link.value.link}
                  >
                    {link.value.linkText}
                  </a>
                );
              })
            : null
        }
      </div>
    </div>
  </div>
</section>
