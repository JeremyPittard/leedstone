---
import type { CTALink } from "src/types/blocks";
import Button from "../elements/Button.astro";
import PageSection from "../objects/PageSection.astro";

const { tagline, title, description, cta, items } = Astro.props.value;
console.log(Astro.props.value);
---

<PageSection class="timeline content-container">
  <p class="mb-3 lg:mb-4 font-semibold">{tagline}</p>
  <h2 class="mb-5 lg:mb-6">{title}</h2>
  <p class="mb-7 lg:mb-8">{description}</p>
  {
    cta ? (
      <div class="flex gap-4">
        {cta.map((link: CTALink, index: number) => (
          <Button
            buttonType="link"
            href={link.value.link}
            variant={index === 0 ? "outline" : "ghost"}
            target={link.discriminant === "external" ? "_blank" : "_self"}
          >
            {link.value.linkText}
          </Button>
        ))}
      </div>
    ) : null
  }
</PageSection>
