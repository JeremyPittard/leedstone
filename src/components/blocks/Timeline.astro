---
import type { CTALink, TimelineItem } from "src/types/blocks";
import Button from "../elements/Button.astro";
import PageSection from "../objects/PageSection.astro";
import DynamicImage from "../elements/DynamicImage.astro";
const { tagline, title, description, cta, items } = Astro.props.value;
---

<PageSection class="timeline content-container animate fade-in">
  <p class="mb-3 text-center font-semibold lg:mb-4">{tagline}</p>
  <h2 class="mb-5 text-center lg:mb-6">{title}</h2>
  <p class="mb-7 text-center lg:mb-8">{description}</p>
  {
    cta ? (
      <div class="flex justify-center gap-4">
        {cta.map((link: CTALink, index: number) => (
          <Button
            buttonType="link"
            href={link.value.link === "home" ? "/" : link.value.link}
            variant={index === 0 ? "outline" : "ghost"}
            target={link.discriminant === "external" ? "_blank" : "_self"}
          >
            {link.value.linkText}
          </Button>
        ))}
      </div>
    ) : null
  }
  {
    items ? (
      <div class="mt-20 grid grid-cols-1 gap-0 lg:grid-cols-3">
        {items.map((step: TimelineItem, index: number) => {
          const { title, description, image } = step;
          return (
            <article>
              <div class="px-14">
                {image ? (
                  <DynamicImage
                    src={`${image}`}
                    alt={""}
                    class="mx-auto mb-8"
                    height={256}
                    width={256}
                  />
                ) : (
                  <p class="text-center text-8xl">{index + 1}</p>
                )}
              </div>
              <div class="px-8 text-center">
                <h3 class="h5 mb-6">{title}</h3>
                <p>{description}</p>
              </div>
            </article>
          );
        })}
      </div>
    ) : null
  }
</PageSection>
