---
import type { CTALink, TimelineItem } from "src/types/blocks";
import Button from "../elements/Button.astro";
import PageSection from "../objects/PageSection.astro";
import DynamicImage from "../elements/DynamicImage.astro";

const { tagline, title, description, cta, items } = Astro.props.value;
---

<PageSection class="timeline content-container">
  <p class="text-center mb-3 lg:mb-4 font-semibold">{tagline}</p>
  <h2 class="text-center mb-5 lg:mb-6">{title}</h2>
  <p class="text-center mb-7 lg:mb-8">{description}</p>
  {
    cta ? (
      <div class="flex gap-4 justify-center">
        {cta.map((link: CTALink, index: number) => (
          <Button
            buttonType="link"
            href={link.value.link === "home" ? "/" : link.value.link}
            variant={index === 0 ? "outline" : "ghost"}
            target={link.discriminant === "external" ? "_blank" : "_self"}
          >
            {link.value.linkText}
          </Button>
        ))}
      </div>
    ) : null
  }
  {
    items ? (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 mt-20">
        <button id="prev">prev</button>
        <button id="next">next</button>
        {items.map((step: TimelineItem, index: number) => {
          const { title, description, image } = step;
          return (
            <article class={`${index > 0 ? "hidden" : "active"} lg:block`}>
              <div class="px-14">
                {image ? (
                  <DynamicImage
                    src={`${image}`}
                    alt={""}
                    class="mb-8 mx-auto"
                    height={256}
                    width={256}
                  />
                ) : (
                  <p class="text-8xl text-center">{index + 1}</p>
                )}
              </div>
              <div class="px-8 text-center">
                <h3 class="h5 mb-6">{title}</h3>
                <p>{description}</p>
              </div>
            </article>
          );
        })}
      </div>
    ) : null
  }
</PageSection>
