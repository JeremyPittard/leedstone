---
import type { CTALink, IconGridItem } from "src/types/blocks";
import Button from "../elements/Button.astro";
import PageSection from "../objects/PageSection.astro";
import DynamicImage from "../elements/DynamicImage.astro";
const { tagline, title, description, cta, items } = Astro.props.value;
---

<PageSection class="icon-grid content-container animate fade-in">
  <p class="mb-3 text-center font-semibold lg:mb-4">{tagline}</p>
  <h2 class="mb-5 text-center lg:mb-6">{title}</h2>
  <p class="mb-7 text-center lg:mb-8">{description}</p>
  {
    cta ? (
      <div class="flex justify-center gap-4">
        {cta.map((link: CTALink, index: number) => (
          <Button
            buttonType="link"
            href={link.value.link === "home" ? "/" : link.value.link}
            variant={index === 0 ? "outline" : "ghost"}
            target={link.discriminant === "external" ? "_blank" : "_self"}
          >
            {link.value.linkText}
          </Button>
        ))}
      </div>
    ) : null
  }
  {
    items ? (
      <div class="mt-20 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {items.map((item: IconGridItem, index: number) => {
          const { title, description, image, link } = item;
          const content = (
            <article class="text-center">
              <div class="mb-6">
                {image ? (
                  <DynamicImage
                    src={`${image}`}
                    alt={title || ""}
                    class="mx-auto mb-4"
                    height={128}
                    width={128}
                  />
                ) : (
                  <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-gray-200">
                    <span class="text-2xl text-gray-500">{index + 1}</span>
                  </div>
                )}
              </div>
              <div>
                <h3 class="h5 mb-4">{title}</h3>
                <p class="text-sm">{description}</p>
              </div>
            </article>
          );

          if (link && link.length > 0) {
            const linkData = link[0];
            const href =
              linkData.value.link === "home" ? "/" : linkData.value.link;
            const target =
              linkData.discriminant === "external" ? "_blank" : "_self";

            return (
              <a
                href={href}
                target={target}
                class="block transition-transform hover:scale-105"
              >
                {content}
              </a>
            );
          }

          return content;
        })}
      </div>
    ) : null
  }
</PageSection>
