---
import type { ContactBlockItem } from "src/types/blocks";
import Button from "../elements/Button.astro";
import PageSection from "../objects/PageSection.astro";
import DynamicImage from "../elements/DynamicImage.astro";
import { getEntry } from "astro:content";
import { Icon } from "astro-icon/components";

const { tagline, title, description, cta } = Astro.props.value;

// Get site settings for contact details
const siteSettings = await getEntry("site-settings", "site-details");
const contactEmail = siteSettings?.data?.contactEmail || "";
const contactPhone = siteSettings?.data?.contactPhone || "";
const contactAddress = siteSettings?.data?.contactAddress || "";
---

<PageSection class="contact-block content-container animate fade-in">
  <p class="text-center mb-3 lg:mb-4 font-semibold">{tagline}</p>
  {title ? <h2 class="text-center mb-5 lg:mb-6">{title}</h2> : null}
  {description ? <p class="text-center mb-7 lg:mb-8">{description}</p> : null}
  {
    cta ? (
      <div class="flex gap-4 justify-center">
        {cta.map((link: any, index: number) => (
          <Button
            buttonType="link"
            href={link.value.link === "home" ? "/" : link.value.link}
            variant={index === 0 ? "outline" : "ghost"}
            target={link.discriminant === "external" ? "_blank" : "_self"}
          >
            {link.value.linkText}
          </Button>
        ))}
      </div>
    ) : null
  }

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-20">
    {
      contactPhone ? (
        <a
          href={`tel:${contactPhone.replaceAll(" ", "")}`}
          class="hover:text-brand-2 transition"
        >
          <article class="text-center">
            <div class="mb-6">
              <Icon name="mdi:phone" class={`inline-block text-6xl`} />
            </div>
            <div>
              <h3 class="h5 mb-4">Phone</h3>
              <p class="text-sm">{contactPhone}</p>
            </div>
          </article>
        </a>
      ) : null
    }
    {
      contactEmail ? (
        <a
          href={`mailto:${contactEmail}`}
          class="hover:text-brand-2 transition"
        >
          <article class="text-center">
            <div class="mb-6">
              <Icon name="mdi:email" class={`inline-block text-6xl`} />
            </div>
            <div>
              <h3 class="h5 mb-4">Email</h3>
              <p class="text-sm">{contactEmail}</p>
            </div>
          </article>
        </a>
      ) : null
    }
    {
      contactAddress ? (
        <a
          href={`https://maps.google.com/?q=${contactAddress}`}
          target="_blank"
          class="hover:text-brand-2 transition"
        >
          <article class="text-center">
            <div class="mb-6">
              <Icon name="mdi:map" class={`inline-block text-6xl`} />
            </div>
            <div>
              <h3 class="h5 mb-4">Find Us</h3>
              <p class="text-sm">{contactAddress}</p>
            </div>
          </article>
        </a>
      ) : null
    }
  </div>
</PageSection>
