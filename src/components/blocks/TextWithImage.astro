---
import Button from "../elements/Button.astro";
import DynamicImage from "../elements/DynamicImage.astro";
import PageSection from "../objects/PageSection.astro";
import type { CTALink } from "../../types/blocks";

const { image, title, description, imageSide, cta, tagline } =
  Astro.props.value;

const imageSideClasses =
  imageSide === "left" ? "lg:flex-row-reverse" : "lg:flex-row";
---

<PageSection class="hero content-container">
  <div
    class={`flex flex-col ${imageSideClasses} lg:flex-row lg:space-between gap-5 lg:gap-20 mb-12 lg:mb-20 items-center`}
  >
    <div class="flex-1">
      <p class="mb-3 lg:mb-4 font-semibold">{tagline}</p>
      <h2 class="mb-5 lg:mb-6">{title}</h2>
      <p class="mb-7 lg:mb-8">{description}</p>
      {
        cta ? (
          <div class="flex gap-4">
            {cta.map((link: CTALink, index: number) => (
              <Button
                buttonType="link"
                href={link.value.link === "home" ? "/" : link.value.link}
                variant={index === 0 ? "outline" : "ghost"}
                target={link.discriminant === "external" ? "_blank" : "_self"}
              >
                {link.value.linkText}
              </Button>
            ))}
          </div>
        ) : null
      }
    </div>
    <div class="flex-1">
      <DynamicImage
        src={`${image}`}
        alt={""}
        class="hero-image"
        width={616}
        height={640}
      />
    </div>
  </div>
</PageSection>
